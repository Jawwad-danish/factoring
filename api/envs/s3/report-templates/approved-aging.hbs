      .p13{text-align: right;padding-left: 22px;margin-top: 0px;margin-bottom: 0px;white-space: nowrap;}

      .td0{padding: 0px;margin: 0px;width: 412px;vertical-align: bottom;}
      .td7{padding: 0px;margin: 0px;width: 94px;vertical-align: bottom;}
      .td9{border-bottom: #cccccc 1px solid;padding: 0px;margin: 0px;width: 94px;vertical-align: bottom;}
      .td10{border-bottom: #cccccc 1px solid;padding: 0px;margin: 0px;width: 318px;vertical-align: bottom;}
      .td11{border-bottom: #cccccc 1px solid;padding: 0px;margin: 0px;width: 97px;vertical-align: bottom;}
      .td12{border-bottom: #cccccc 1px solid;padding: 0px;margin: 0px;width: 118px;vertical-align: bottom;}
