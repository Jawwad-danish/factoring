        width: 80px;
        vertical-align: bottom;
      }

      .td23 {
        border-bottom: #cccccc 1px solid;
        padding: 0px;
        margin: 0px;
        padding-bottom: 10px;
        width: 94px;
        vertical-align: bottom;
      }

      .tr0 {
        height: 24px;
      }

      .tr1 {
        height: 38px;
      }

      .tr2 {
        height: 20px;
      }

      .tr3 {
        height: 22px;
      }

