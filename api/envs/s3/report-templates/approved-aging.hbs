      .ft6{font: 14px 'Arial';line-height: 16px;}
      .ft7{font: 13px 'Arial';line-height: 16px;}

      .p0{text-align: center;margin-top: 30px;}
      .p1{text-align: left;margin-top: 0px;margin-bottom: 0px;}
