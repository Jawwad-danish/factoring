        padding-left: 20px;
        margin: 0px;
        width: 200px;
        vertical-align: top;
      }

      .td18 {
        border-bottom: #cccccc 1px solid;
        padding: 0px;
        padding-left: 20px;
        margin: 0px;
        padding-bottom: 10px;
        width: 200px;
        vertical-align: bottom;
      }

      .td3 {
        padding: 0px;
        padding-top: 10px;
        margin: 0px;
        width: 60px;
        vertical-align: top;
      }

      .td19 {
        border-bottom: #cccccc 1px solid;
        padding: 0px;
        margin: 0px;
        padding-bottom: 10px;
        width: 60px;
        vertical-align: bottom;
      }

      .td20 {
        border-bottom: #cccccc 1px solid;
        padding: 0px;
        margin: 0px;
