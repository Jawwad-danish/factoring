      .td15{border-bottom: #cccccc 1px solid;padding: 0px;margin: 0px;width: 69px;vertical-align: bottom;}
      .td16{border-bottom: #cccccc 1px solid;padding: 0px;margin: 0px;width: 87px;vertical-align: bottom;}

      .td8 {
        padding: 0px;
        padding-top: 10px;
        margin: 0px;
        width: 60px;
        vertical-align: top;
      }

      .td24 {
        border-bottom: #cccccc 1px solid;
        padding: 0px;
        margin: 0px;
