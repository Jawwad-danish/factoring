# API Configuration
PORT=4000
ORIGINS = 'http://localhost:8080' #CORS
ALB_DOMAIN_ALIAS = 'localhost:4000'

# AWS Defaults
AWS_DEFAULT_REGION=us-east-1

#localstack endpoint - http://localhost:4566/ -> redirect for aws resources if populated, add only to local envs
AWS_DEFAULT_ENDPOINT=

# AWS App Config related configurations
AWS_APPCONFIG_ENVIRONMENT=development
AWS_APPCONFIG_APPLICATION=Bobtail-NG
AWS_APPCONFIG_PROFILE=General
AWS_APPCONFIG_ENABLE_POOLING=true
AWS_APPCONFIG_POLL_INTERVAL=86400

# Database related configurations
DB_INITIAL_CONNECTION_TIMEOUT=30000

SYSTEM_ID=d554a9ce-2b8c-4fd0-80cc-316b548e6fab
# SYSTEM_ID=b594ade4-e360-4d30-81fa-7d03cdce9251 #PROD
SYSTEM_EMAIL=system@bobtail.com
CROSS_ACCOUNT_ADMIN_EMAIL=local@bobtailtest.com

# Scripts
SCRIPT_SYSTEM_ID=d554a9ce-2b8c-4fd0-80cc-316b548e6fab #LOCAL
# SCRIPT_SYSTEM_ID=8eccb38b-28bf-456b-9519-72a0814296ad #QA
# SCRIPT_SYSTEM_ID=b8d142a8-6368-4750-bcde-c20eaf968ac8 #STAGING
# SCRIPT_SYSTEM_ID=b594ade4-e360-4d30-81fa-7d03cdce9251 #PROD
SCRIPT_IMPORT_BROKERS_PATH=/tmp/bobtail/export/debtors
SCRIPT_IMPORT_INVOICES_PATH=/tmp/bobtail/export/invoices
SCRIPT_IMPORT_BROKER_PAYMENTS_PATH=/tmp/bobtail/export/debtor_payments
SCRIPT_IMPORT_CLIENT_PAYMENTS_PATH=/tmp/bobtail/export/client_payments
SCRIPT_IMPORT_BATCH_PAYMENTS_PATH=/tmp/bobtail/export/batch_payments
SCRIPT_IMPORT_RESERVE_ACCOUNT_FUNDS_PATH=/tmp/bobtail/export/reserve_account_funds
SCRIPT_IMPORT_RESERVES_PATH=/tmp/bobtail/export/reserves
SCRIPT_IMPORT_CLIENT_BROKER_ASSIGNMENTS_PATH=/tmp/bobtail/export/client_debtor_assignments
SCRIPT_IMPORT_CLIENTS_DATA_PATH=/tmp/bobtail/export/clients
SCRIPT_IMPORT_USERS_PATH=/tmp/bobtail/export/users
SCRIPT_IMPORT_HISTORY_INVOICES_PATH=/tmp/bobtail/export_history/invoices_history
SCRIPT_IMPORT_PROCESSING_NOTES_PATH=/tmp/bobtail/export/processing-notes
SCRIPT_IMPORT_AUDIT_LOGS_BROKER_PAYMENTS_PATH=/tmp/bobtail/export/audit-logs/debtor-payments
SCRIPT_PERUSE_URL=https://api-service.staging.peruseml.com
SCRIPT_PERUSE_KEY=
