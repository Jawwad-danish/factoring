SYSTEM_ID=b8d142a8-6368-4750-bcde-c20eaf968ac8
SYSTEM_EMAIL=system@bobtail.com
CROSS_ACCOUNT_ADMIN_EMAIL=testbobtail+johnsocttest3@gmail.com

# Logging
NO_COLOR=true
