# AWS Defaults
AWS_DEFAULT_REGION=us-east-1

# App Config related configurations
AWS_APPCONFIG_ENVIRONMENT=staging
AWS_APPCONFIG_APPLICATION=Bobtail-NG
AWS_APPCONFIG_PROFILE=General
AWS_APPCONFIG_ENABLE_POOLING=true
AWS_APPCONFIG_POLL_INTERVAL=86400

# Database related configurations
DB_INITIAL_CONNECTION_TIMEOUT=30000

# CORS
