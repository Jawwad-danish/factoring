# AWS Defaults
AWS_DEFAULT_REGION=us-east-1

# App Config related configurations
AWS_APPCONFIG_ENVIRONMENT=development
AWS_APPCONFIG_APPLICATION=Bobtail-NG
AWS_APPCONFIG_PROFILE=General
AWS_APPCONFIG_ENABLE_POOLING=true
AWS_APPCONFIG_POLL_INTERVAL=86400

# Database related configurations
DB_INITIAL_CONNECTION_TIMEOUT=30000

# CORS
ORIGINS = 'http://localhost,http://localhost:8080,https://bobtailtest.com,https://qa-app.bobtailtest.com'
SYSTEM_ID=8eccb38b-28bf-456b-9519-72a0814296ad
SYSTEM_EMAIL=system@bobtail.com
CROSS_ACCOUNT_ADMIN_EMAIL=paul@bobtail.com

# Logging
NO_COLOR=true