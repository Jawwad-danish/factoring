  "item": [
    {
      "name": "E2E Tests",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Get Auth0 Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "pm.test(\"Tokens are in response\", function () {",
                      "    const response = pm.response.json();",
                      "    pm.expect(response.access_token).to.not.be.undefined;",
                      "",
                      "    pm.environment.set(\"auth0_access_token\", response.access_token);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"client_id\": \"{{auth0_client_id}}\",\n  \"grant_type\": \"password\",\n  \"username\": \"{{auth0_username}}\",\n  \"password\": \"{{auth0_password}}\",\n  \"scope\": \"openid profile email\",\n  \"audience\": \"{{auth0_audience}}\"\n}\n\n\n\n",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "https://{{auth0_domain}}/oauth/token",
                  "protocol": "https",
                  "host": ["{{auth0_domain}}"],
                  "path": ["oauth", "token"]
                }
              },
              "response": []
            }
          ]
        },
        {
          "name": "Invoices",
          "item": [
            {
              "name": "Create Invoice",
              "item": [
                {
                  "name": "Create Invoice-HappyPath",
                  "item": [
                    {
                      "name": "Create Invoice",
                      "event": [
                        {
                          "listen": "test",
                          "script": {
                            "exec": [
                              "const brokerId = pm.environment.get(\"brokerId\");",
                              "const clientId = pm.environment.get(\"clientId\")",
                              "const requestData = JSON.parse(request.data);",
                              "",
                              "//to return the invoice total value",
                              "const invoiceTotal = (lineHaulRate, lumper, detention, advance) => {",
                              "    return (Number(lineHaulRate)+Number(lumper)+Number(detention)-Number(advance)).toString();   ",
                              "    }",
                              "",
                              "pm.test(\"Status code is 201\", function () {",
                              "    pm.response.to.have.status(201);",
                              "    const body = pm.response.json();",
                              "    pm.environment.set(\"invoiceId\", body.id);",
                              "});",
                              "",
                              "//client is set",
                              "pm.test(`ClientID sent in payload matches the ClientID in response | ${clientId}`, () => {",
                              "    const responseJson = pm.response.json();",
                              "    pm.expect(responseJson.clientId).to.eql(clientId);",
                              "});",
                              "",
                              "// //broker is set ",
                              "// pm.test(`BrokerID sent in payload matches the BrokerID in response | ${brokerId}`, () => {",
                              "//     const responseJson = pm.response.json();",
                              "//     console.log(responseJson.brokerId);",
                              "//     pm.expect(responseJson.brokerId).to.eql(brokerId);",
                              "// });",
                              "",
                              "//testing invoice body response",
                              "pm.test(\"Invoice Data\", () => {",
                              "  const responseJson = pm.response.json();",
                              "  pm.expect(responseJson.loadNumber).to.eql(\"1379957\");",
                              "  pm.expect(responseJson.displayId).to.eql('666558');",
                              "  pm.expect(responseJson.lineHaulRate).to.eql('90000');",
                              "  pm.expect(responseJson.detention).to.eql('0');",
                              "  pm.expect(responseJson.lumper).to.eql('0');",
                              "  pm.expect(responseJson.advance).to.eql('0');",
                              "  pm.expect(responseJson.note).to.eql(\"Test Invoice Note\");",
                              "  pm.expect(responseJson.expedited).to.eql(false);",
                              "});",
                              "",
                              "//verify invoioce total value are the same as in the request based on the formula",
                              "pm.test(\"Check Invoice Value\", () => {",
                              "  const responseJson = pm.response.json();",
                              "  console.log(requestData);",
                              "    pm.expect(responseJson.value).to.eql(invoiceTotal(requestData.lineHaulRate,requestData.lumper,requestData.detention,requestData.advance));",
                              "});",
                              "",
                              "// Response latency is acceptable if it is under 10 seconds",
                              "tests['Response latency is acceptable'] = responseTime < 10000;",
                              ""
                            ],
                            "type": "text/javascript"
                          }
                        }
                      ],
                      "request": {
                        "method": "POST",
                        "header": [
                          {
                            "key": "x-correlation-id",
                            "value": "{{$guid}}",
                            "type": "default"
                          }
                        ],
                        "body": {
                          "mode": "raw",
                          "raw": "{\n    \"clientId\": \"{{clientId}}\",\n    \"brokerId\": \"{{brokerId}}\",\n    \"loadNumber\": \"1379957\",\n    \"displayId\": \"666558\",\n    \"lineHaulRate\": \"90000\",\n    \"detention\": \"0\",\n    \"lumper\": \"0\",\n    \"advance\": \"0\",\n    \"note\": \"Test Invoice Note\",\n    \"memo\": \"Test Invoice Memo\",\n    \"expedited\": false\n}",
                          "options": {
                            "raw": {
                              "language": "json"
                            }
                          }
                        },
                        "url": {
                          "raw": "{{host}}/invoices",
                          "host": ["{{host}}"],
                          "path": ["invoices"]
                        }
                      },
                      "response": []
                    }
                  ]
                }
