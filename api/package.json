{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "db:connect:info": "echo '-----\nConnect to DB using localhost:1433' && echo \"For credentials run: aws --profile $AWS_PROFILE --region us-east-1 secretsmanager get-secret-value --secret-id $ENV-BobtailAuroraDatabaseSecret --query 'SecretString' --output text | jq\n------\"",
    "db:connect": "npm run db:connect:info && aws ssm start-session --profile $AWS_PROFILE --region us-east-1 --target $(aws --profile $AWS_PROFILE ec2 describe-instances --region us-east-1 --filters \"Name=tag:Name,Values=$ENV-bastion-host\" \"Name=instance-state-name,Values=running\" --query 'Reservations[*].Instances[*].InstanceId' --output text) --document-name AWS-StartPortForwardingSessionToRemoteHost --parameters host=\"$(aws --profile $AWS_PROFILE rds describe-db-cluster-endpoints --query 'DBClusterEndpoints[*].Endpoint' --filters 'Name=db-cluster-endpoint-type,Values=writer' --db-cluster-identifier $ENV-bobtailng-v2 --output text | cut -f1)\",portNumber=\"5432\",localPortNumber=\"1433\"",
    "db:connect:dev": "export ENV=ic-dev && export AWS_PROFILE=bobtail-sandbox && npm run db:connect",
    "db:connect:staging": "export ENV=ic-staging && export AWS_PROFILE=bobtail-sandbox && npm run db:connect",
    "db:connect:prod": "export ENV=ic-prod && export AWS_PROFILE=bobtail-20 && npm run db:connect",
    "db:connect:migration:start-session": "aws ssm start-session --region us-east-1 --target $(aws ec2 describe-instances --region us-east-1 --filters \"Name=tag:Name,Values=$ENV-bastion-host\" \"Name=instance-state-name,Values=running\" --query 'Reservations[*].Instances[*].InstanceId' --output text) --document-name AWS-StartPortForwardingSessionToRemoteHost --parameters host=\"$(aws rds describe-db-cluster-endpoints --query 'DBClusterEndpoints[*].Endpoint' --filters 'Name=db-cluster-endpoint-type,Values=writer' --db-cluster-identifier $ENV-bobtailng-v2 --output text | cut -f1)\",portNumber=\"5432\",localPortNumber=\"1433\" &",
    "db:connect:migration:stop-session": "aws ssm terminate-session --session-id $(aws ssm describe-sessions --state \"Active\" --filters \"key=Owner,value=$(aws sts get-caller-identity --query 'Arn' --output text)\" \"key=Target,value=$(aws ec2 describe-instances --region us-east-1 --filters \"Name=tag:Name,Values=$ENV-bastion-host\" \"Name=instance-state-name,Values=running\" --query 'Reservations[*].Instances[*].InstanceId' --output text)\" \"key=Status,value=Connected\" --query 'Sessions[].{SessionId:SessionId,StartDate:StartDate} | reverse(sort_by(@, &StartDate)) | [0].SessionId' --output text)",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=local nest start",
    "start:dev": "npm run start -- --watch",
    "start:debug": "npm run start -- --debug --watch",
    "start:e2e": "NODE_ENV=test nest start",
    "start:worker:local": "NODE_ENV=local nodemon -r tsconfig-paths/register src/modules/worker/entrypoint.ts",
    "seed:dev": "NODE_ENV=local ts-node -r tsconfig-paths/register src/seeding/seed.ts",
    "seed:dirty-invoices": "NODE_ENV=local ts-node -r tsconfig-paths/register src/seeding/seed-dirty-invoices.ts",
    "seed:e2e": "NODE_ENV=test ts-node -r tsconfig-paths/register src/seeding/seed.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest  --coverage --testPathPattern=\".*.unit.spec.ts\"",
    "test:extract-coverage": "ts-node test/coverageExtract.ts",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "newman run ./src/postman/collection/Bobtail-NG-E2E.postman_collection.json -e ./src/postman/env/bobtail-ng.e2e.postman_environment.json",
    "test:integration": "JEST_TESTS_TYPE=integration jest --testPathPattern=\".*.integration.spec.ts\"",
    "test:integration:serial": "JEST_TESTS_TYPE=integration jest --runInBand --testPathPattern=\".*.integration.serial.spec.ts\"",
    "migration:create": "NODE_ENV=local mikro-orm migration:create -- dotenv_config_path=envs/migration-local.env",
    "migration:run:local": "NODE_ENV=local mikro-orm migration:up -- dotenv_config_path=envs/migration-local.env",
    "migration:run:test": "NODE_ENV=test mikro-orm migration:up -- dotenv_config_path=envs/migration-test.env",
    "migration:revert:local": "NODE_ENV=local mikro-orm migration:down -- dotenv_config_path=envs/migration-local.env",
    "migration:run:ic-dev": "NODE_ENV=development DB_HOST=127.0.0.1 DB_PORT=1433 mikro-orm migration:up",
    "migration:revert:ic-dev": "NODE_ENV=development DB_HOST=127.0.0.1 DB_PORT=1433 mikro-orm migration:down",
    "migration:run:ic-staging": "NODE_ENV=staging DB_HOST=127.0.0.1 DB_PORT=1433 mikro-orm migration:up",
    "migration:revert:ic-staging": "NODE_ENV=staging DB_HOST=127.0.0.1 DB_PORT=1433 mikro-orm migration:down",
    "migration:run:ic-prod": "NODE_ENV=production DB_HOST=127.0.0.1 DB_PORT=1433 mikro-orm migration:up",
    "migration:revert:ic-prod": "NODE_ENV=production DB_HOST=127.0.0.1 DB_PORT=1433 mikro-orm migration:down",
    "script:dev:verify:invoices": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/reports/verification-engine-script.ts",
    "script:dev:report:duplicates": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/reports/duplicate-engine-script.ts",
    "script:dev:import:all": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/import-all.ts",
    "script:dev:import:brokers": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/import-brokers.ts",
    "script:dev:import:single-invoice": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/import-single.ts",
    "script:dev:import:requests": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/requests-replay/requests-replay.script.ts",
    "script:dev:import:users": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/users/import-users.ts",
    "script:dev:import:roles": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/users/assign-auth0-roles.ts",
    "script:dev:import:history": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/history/invoices/import-invoices-history.ts",
    "script:dev:import:processing-notes": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/processing-notes/import-processing-notes.ts",
    "script:dev:import:audit-log": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/import-audit-logs.ts",
    "script:dev:import:audit-log-optimal": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/audit-logs/import-audit-logs-broker-payments-optimal.ts",
    "script:dev:parity:all": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/parity-all.ts",
    "script:dev:parity:summary": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-parity/parity-summary.ts",
    "script:dev:segment:sync": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/segment/sync-segment.ts",
    "script:dev:peruse:classify": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/peruse/peruse-classify-documents.ts",
    "script:dev:peruse:process-classified": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/peruse/peruse-process-classified-documents.ts",
    "script:dev:peruse:process-verified": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/peruse/peruse-process-verify-loads.ts",
    "script:dev:peruse:create-load": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/peruse/peruse-create-load.ts",
    "script:dev:peruse:process-created-loads": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/peruse/peruse-process-created-loads.ts",
    "script:dev:peruse:process-jobs": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/peruse/peruse-process-jobs.ts",
    "script:dev:cleanup:all": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/cleanup/remove-data-for-clients.ts",
    "script:dev:sync:client-payment-status": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/v1-migrations/sync-client-payment-status.ts",
    "script:dev:sync:bulk-invoice-payment-date": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/invoices/bulk-invoice-payment-date-sync.ts",
    "script:dev:update:broker:limits": "NODE_ENV=local ts-node -r tsconfig-paths/register src/scripts/broker-limit/update-broker-limits.ts",
    "mock:external-services": "PORT=4001 ts-node src/scripts/mock-server/external-services.mock-server.ts"
  },
